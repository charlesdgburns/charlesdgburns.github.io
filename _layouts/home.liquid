<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ site.title }}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <!-- Start invisible — JS adds .ready to fade in -->
    <style>body { opacity: 0; background: #f4f2ee; }</style>

    <link rel="stylesheet" href="{{ '/css/mosaic.css' | relative_url }}">
</head>
<body>

<header>
    <a class="site-name" href="{{ '/' | relative_url }}">{{ site.title | downcase }}</a>
    <nav>
        <ul class="section-nav">
            {% for section in site.sections %}
            <li><a data-section="{{ section.name }}">{{ section.name }}</a></li>
            {% endfor %}
        </ul>
    </nav>
</header>

<div class="mosaic-wrap">
    <div class="mosaic" id="mosaic"></div>
</div>

<div id="exit-overlay"></div>
<div id="border-expander"></div>

<script>
// ── Page data — generated by Jekyll at build time ──
const pages = [
    {% for p in site.pages %}
        {% if p.title and p.parent %}
        {
            title:   {{ p.title       | jsonify }},
            section: {{ p.parent      | jsonify }},
            desc:    {{ p.description | default: "" | jsonify }},
            size:    {{ p.size        | default: "medium" | jsonify }},
            href:    {{ p.url | relative_url | jsonify }},
            {% if p.image %}
            image:   {{ p.image | relative_url | jsonify }},
            {% endif %}
        },
        {% endif %}
    {% endfor %}
    {% for collection in site.collections %}
        {% for doc in collection.docs %}
            {% if doc.title and doc.parent %}
            {
                title:   {{ doc.title       | jsonify }},
                section: {{ doc.parent      | jsonify }},
                desc:    {{ doc.description | default: "" | jsonify }},
                size:    {{ doc.size        | default: "medium" | jsonify }},
                href:    {{ doc.url | relative_url | jsonify }},
                {% if doc.image %}
                image:   {{ doc.image | relative_url | jsonify }},
                {% endif %}
            },
            {% endif %}
        {% endfor %}
    {% endfor %}
];
</script>
<script src="{{ '/js/mosaic.js' | relative_url }}"></script>
</body>
</html>
