<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if page.title and page.url != "/" %}{{ page.title }} – {% endif %}{{ site.title }}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <style>main { opacity: 0; background: #f4f2ee; }</style>
    <link rel="stylesheet" href="{{ 'assets/css/mosaic.css' | relative_url }}">
</head>

<!--
    data-path is the current page's directory path.
    mosaic.js uses this to filter cards:
      - "/" → show all cards
      - "/learning/" → show cards whose path starts with /learning/
      - "/learning/degist/" → show cards whose path starts with /learning/degist/
    
    data-section is the top-level section name for nav highlighting.
-->
<body
    data-path="{{ page.dir }}"
    data-section="{{ page.dir | split: '/' | compact | first | default: '' }}">

<header>
    {% include navigation.html %}
</header>


<div class="mosaic-wrap">
    <div class="mosaic" id="mosaic"></div>
</div>

<div id="exit-overlay"></div>
<div id="border-expander"></div>

<script>
// ── All pages, injected by Jekyll at build time ──────────────────────────
// Each entry carries its full path so JS can filter by directory prefix.
const ALL_PAGES = [
    {% for p in site.pages %}
        {% if p.title and p.dir != "/" %}
        {
            title:   {{ p.title                     | jsonify }},
            path:    {{ p.dir                        | jsonify }},  // e.g. "/learning/degist/"
            section: {{ p.dir | split: "/" | compact | first | jsonify }}, // top-level section
            desc:    {{ p.description | default: "" | jsonify }},
            size:    {{ p.mosaic_size | default: "medium" | jsonify }},
            href:    {{ p.url | relative_url          | jsonify }},
            {% if p.image %}
            image:   {{ p.image | relative_url        | jsonify }},
            {% endif %}
        },
        {% endif %}
    {% endfor %}
];

// The directory of the current page — cards must have a path that starts
// with this prefix (and goes one level deeper) to appear in the mosaic.
// "/" means home → show immediate children of each section.
const PAGE_PATH  = {{ page.dir    | jsonify }};   // e.g. "/learning/"
const PAGE_SECTION = {{ page.dir | split: "/" | compact | first | default: "" | jsonify }};
</script>
<script src="{{ '/assets/js/mosaic.js' | relative_url }}"></script>



</body>
</html>
