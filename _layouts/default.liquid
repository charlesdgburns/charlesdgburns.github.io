<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if page.title %}{{ page.title }} – {% endif %}{{ site.title }}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">

    <style>
        main { opacity: 0; } 
        body { background: #f4f2ee; margin: 0; opacity: 1; }
    </style>
    <link rel="stylesheet" href="{{ 'assets/css/style.css' | relative_url }}">
</head>

<body data-section="{{ page.dir | split: '/' | compact | first | default: '' }}">

<header>
    {% include navigation.html %}
</header>

<main class="page-content">
    <div class="page-body">
        {{ content }}
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        // Fade in ONLY the main content
        const mainContent = document.querySelector('main');
        if (mainContent) {
            mainContent.style.transition = 'opacity 0.5s ease';
            mainContent.style.opacity = '1';
        }
    });
</script>

</body>
</html>