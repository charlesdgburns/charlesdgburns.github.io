---
layout: default
---

<div class="section-header">
    {% if page.description %}
        <div class="definition">
            <span class="definition-label">{{ page.title | downcase }}</span>
            <span class="definition-separator">·</span>
            <span class="definition-text">{{ page.description }}</span>
        </div>
    {% endif %}
</div>

{% assign section_name = page.section %}
{% assign child_pages = site.pages | where: "parent", section_name | sort: "order" %}

{% assign collection_children = "" | split: "" %}
{% for collection in site.collections %}
    {% assign items = collection.docs | where: "parent", section_name %}
    {% assign collection_children = collection_children | concat: items %}
{% endfor %}

{% assign all_cards = child_pages | concat: collection_children | sort: "order" %}

{% if all_cards.size > 0 %}
<div class="cards-grid">
    {% for card in all_cards %}
        {% if card.image %}
            <a href="{{ card.url | relative_url }}" class="card has-image" style="animation-delay: {{ forloop.index0 | times: 80 }}ms">
                <div class="card-image">
                    <img src="{{ card.image | relative_url }}" alt="{{ card.title }}">
                </div>
                <div class="card-body">
                    <h3 class="card-title">{{ card.title }}</h3>
                    {% if card.description %}<p class="card-description">{{ card.description }}</p>{% endif %}
                </div>
            </a>
        {% else %}
            <a href="{{ card.url | relative_url }}" class="card no-image" style="animation-delay: {{ forloop.index0 | times: 80 }}ms">
                <div class="card-body">
                    <h3 class="card-title">{{ card.title }}</h3>
                    {% if card.description %}<p class="card-description">{{ card.description }}</p>{% endif %}
                </div>
            </a>
        {% endif %}
    {% endfor %}
</div>
{% else %}
<div class="cards-empty">
    <p>Nothing here yet.</p>
</div>
{% endif %}

{{ content }}
